:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #18181b;
  background: #f4f4f5;
  line-height: 1.4;
  font-weight: 400;
}

* { box-sizing: border-box; }
html, body, #root { margin: 0; min-height: 100%; }
button, input, textarea { font: inherit; }

body {
  background:
    radial-gradient(circle at top, rgba(255,255,255,0.95), rgba(244,244,245,1) 42%),
    #f4f4f5;
}

.app-shell { min-height: 100vh; padding: 20px 14px 40px; }
.app-container { max-width: 460px; margin: 0 auto; display: grid; gap: 16px; }

.hero {
  background: #18181b;
  color: white;
  border-radius: 28px;
  padding: 22px;
  box-shadow: 0 20px 40px rgba(24, 24, 27, 0.22);
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
}

.hero h1 { margin: 8px 0 8px; font-size: 1.9rem; line-height: 1.05; }
.hero-copy { margin: 0; color: #d4d4d8; font-size: 0.95rem; }
.hero-icon {
  background: rgba(255,255,255,0.08);
  border-radius: 18px;
  padding: 12px;
  display: grid;
  place-items: center;
}

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.72rem;
  font-weight: 700;
}
.eyebrow.muted { color: rgba(255,255,255,0.65); }
.eyebrow.gray { color: #71717a; }

.card, .recommend-card {
  background: white;
  border-radius: 28px;
  padding: 18px;
  box-shadow: 0 8px 24px rgba(24, 24, 27, 0.08);
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}
.card-header h2 { margin: 0; font-size: 1.08rem; }
.icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 16px;
  background: #f4f4f5;
  display: grid;
  place-items: center;
  color: #52525b;
}
.subtle {
  color: #71717a;
  margin: 4px 0 0;
  font-size: 0.92rem;
}
.smallish { margin: 6px 0 0; opacity: 0.82; }

.stack { display: grid; gap: 10px; }
.top-gap { margin-top: 12px; }

.input, .textarea {
  width: 100%;
  border: 1px solid #e4e4e7;
  background: #fff;
  border-radius: 18px;
  padding: 14px 15px;
  color: #18181b;
}
.textarea { min-height: 110px; resize: vertical; }

.metric-box {
  background: #f4f4f5;
  border-radius: 20px;
  padding: 12px;
}
.metric-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}
.metric-row.top { align-items: flex-start; }

.progress-shell {
  margin-top: 10px;
  height: 9px;
  width: 100%;
  background: #e4e4e7;
  border-radius: 999px;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  background: #18181b;
  border-radius: 999px;
}

.section-block {
  background: #fafafa;
  border-radius: 20px;
  padding: 12px;
}
.section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #3f3f46;
  font-weight: 700;
  font-size: 0.92rem;
  margin-bottom: 10px;
}

.toggle-row {
  width: 100%;
  border: 1px solid #e4e4e7;
  background: white;
  border-radius: 20px;
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  text-align: left;
  color: #18181b;
}
.toggle-row.checked {
  background: #18181b;
  color: white;
  border-color: #18181b;
  box-shadow: 0 10px 20px rgba(24,24,27,0.16);
}
.tick {
  width: 24px;
  height: 24px;
  border-radius: 999px;
  border: 1px solid #d4d4d8;
  display: grid;
  place-items: center;
  color: transparent;
  flex: 0 0 24px;
}
.tick.checked {
  background: white;
  color: #18181b;
  border-color: white;
}

.recommend-card h2 { margin: 8px 0 0; font-size: 1.4rem; }
.recommend-note { margin: 14px 0 0; font-size: 0.96rem; }
.recommend-dark { background: #18181b; color: white; }
.recommend-soft { background: #f4f4f5; color: #18181b; }
.recommend-light { background: white; color: #18181b; }
.pill {
  background: rgba(255,255,255,0.7);
  color: #18181b;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
  white-space: nowrap;
}
.pill.dark {
  background: rgba(255,255,255,0.12);
  color: white;
}
.recommend-dark .pill { background: rgba(255,255,255,0.12); color: white; }
.pill-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
}
.mini-pill {
  background: rgba(255,255,255,0.72);
  color: #18181b;
  padding: 8px 10px;
  border-radius: 999px;
  font-size: 0.77rem;
}
.recommend-dark .mini-pill {
  background: rgba(255,255,255,0.14);
  color: white;
}

.agent-hero {
  background: #18181b;
  color: white;
  border-radius: 26px;
  padding: 18px;
}
.agent-hero h3 { margin: 8px 0 0; font-size: 1.2rem; line-height: 1.15; }
.agent-copy { color: #d4d4d8; margin: 12px 0 0; }
.soft-card {
  border: 1px solid #e4e4e7;
  background: white;
  border-radius: 24px;
  padding: 14px;
}
.soft-title {
  font-size: 1.05rem;
  font-weight: 700;
  margin-top: 8px;
}
.issue-chip {
  background: #fafafa;
  border-radius: 18px;
  padding: 12px 13px;
  font-size: 0.94rem;
  font-weight: 600;
}
.issue-chip.empty {
  color: #52525b;
  font-weight: 500;
}
.quote-box {
  background: #fafafa;
  border-radius: 20px;
  padding: 14px;
  color: #3f3f46;
  line-height: 1.6;
}

.button-row, .action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.button {
  border: 1px solid #e4e4e7;
  background: white;
  color: #18181b;
  border-radius: 18px;
  padding: 13px 14px;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  min-height: 48px;
  cursor: pointer;
}
.button.primary {
  background: #18181b;
  color: white;
  border-color: #18181b;
}
.button.secondary {
  background: white;
}
.hidden { display: none; }

.photo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.photo-card {
  border: 1px solid #e4e4e7;
  border-radius: 18px;
  overflow: hidden;
  background: white;
}
.photo-card img {
  width: 100%;
  height: 132px;
  object-fit: cover;
  display: block;
}
.photo-meta {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  align-items: center;
  padding: 8px;
  font-size: 0.75rem;
  color: #52525b;
}
.photo-meta span {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.icon-button {
  border: none;
  background: #f4f4f5;
  border-radius: 10px;
  width: 28px;
  height: 28px;
  display: grid;
  place-items: center;
  cursor: pointer;
  color: #52525b;
}

.saved-job {
  border: 1px solid #e4e4e7;
  border-radius: 20px;
  padding: 12px;
  background: white;
  display: grid;
  gap: 10px;
}
.saved-title {
  font-weight: 700;
  margin-bottom: 4px;
}

@media (min-width: 520px) {
  .app-shell { padding-top: 28px; }
}


:root {
  --brand-bg: #f6f4ef;
  --brand-card: #ffffff;
  --brand-ink: #1f2937;
  --brand-deep: #2e3b2f;
  --brand-deep-2: #465a3a;
  --brand-accent: #a57a43;
  --brand-accent-soft: #d9bf95;
  --brand-border: #e7e1d5;
  --brand-muted: #6b7280;
}

body {
  background:
    radial-gradient(circle at top, rgba(255,255,255,0.96), rgba(246,244,239,1) 42%),
    var(--brand-bg);
}

.hero {
  background: linear-gradient(135deg, var(--brand-deep), var(--brand-deep-2));
}

.card, .recommend-card {
  background: var(--brand-card);
  box-shadow: 0 10px 28px rgba(46, 59, 47, 0.10);
}

.card-header h2, .soft-title, .saved-title, .toggle-row, .input, .textarea {
  color: var(--brand-ink);
}

.icon-wrap, .metric-box, .section-block, .quote-box, .issue-chip, .tick, .icon-button {
  background: #f8f5ef;
}

.icon-wrap, .section-title, .subtle, .photo-meta, .eyebrow.gray {
  color: var(--brand-muted);
}

.input, .textarea, .soft-card, .photo-card, .saved-job, .toggle-row, .button, .issue-chip, .card, .recommend-card {
  border-color: var(--brand-border);
}

.toggle-row.checked, .button.primary, .progress-bar {
  background: var(--brand-deep);
  border-color: var(--brand-deep);
  color: white;
}

.tick.checked {
  color: var(--brand-deep);
}

.recommend-dark {
  background: linear-gradient(135deg, var(--brand-deep), var(--brand-deep-2));
}

.recommend-soft {
  background: linear-gradient(135deg, #f4ede3, #fbf9f4);
}

.pill, .mini-pill {
  background: rgba(255,255,255,0.82);
  color: var(--brand-deep);
}

.agent-hero {
  background: linear-gradient(135deg, var(--brand-deep), var(--brand-deep-2));
}

.hero-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
}

.hero-mark {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--brand-accent), var(--brand-accent-soft));
  color: white;
  display: grid;
  place-items: center;
  font-weight: 800;
  letter-spacing: 0.04em;
  box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

.hero-brandtext {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.hero-brandtext strong {
  font-size: 0.95rem;
}

.hero-brandtext span {
  color: #d6ddd4;
  font-size: 0.74rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
}

.install-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 18px;
  background: #f4ede3;
  border: 1px solid var(--brand-border);
}

.install-banner p {
  margin: 0;
  color: var(--brand-ink);
  font-size: 0.86rem;
}

.button.accent {
  background: var(--brand-accent);
  color: white;
  border-color: var(--brand-accent);
}

.footer-note {
  text-align: center;
  color: var(--brand-muted);
  font-size: 0.8rem;
  padding-bottom: 12px;
}
